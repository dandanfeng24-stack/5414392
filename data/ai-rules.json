    {"field":"productFoundation","match":"已经有可售产品","effects":{"productization":16,"operation":6},"reason":"已有可售产品，产品化验证基础较好。","factorType":"positive"},
    {"field":"productFoundation","match":"有样品，但包装和定价不成熟","effects":{"productization":8,"operation":-2},"reason":"已有样品但需要补齐包装、定价和渠道表达。","factorType":"positive"},
    {"field":"productFoundation","match":"可以做成小件伴手礼","effects":{"productization":12,"gift":8,"operation":4},"reason":"具备轻量 SKU 转化条件，适合先做低门槛伴手礼测试。","factorType":"positive"},
    {"field":"productFoundation","match":"可以做成中高端礼品","effects":{"productization":9,"gift":14},"reason":"具备礼品价格带潜力，但需要更强包装和价值解释。","factorType":"positive"},
    {"field":"productFoundation","match":"更适合做材料包","effects":{"productization":7,"course":8,"operation":4},"reason":"材料包有利于课程和体验标准化。","factorType":"positive"},
    {"field":"productFoundation","match":"更适合做定制产品","effects":{"productization":5,"gift":8,"operation":-4},"reason":"定制产品有溢价空间，但交付周期和服务边界要更清晰。","factorType":"positive"},
    {"field":"productFoundation","match":"产品制作周期较长","effects":{"productization":-8,"operation":-8},"reason":"制作周期较长会影响库存、交付和游客即时购买。","factorType":"negative"},
    {"field":"productFoundation","match":"产品成本较高","effects":{"productization":-7,"gift":-4},"reason":"成本较高会压缩入门 SKU 和普通游客购买空间。","factorType":"negative"},
    {"field":"productFoundation","match":"产品易损 / 不便携","effects":{"productization":-8,"gift":-8},"reason":"易损或不便携会降低伴手礼和游客携带适配度。","factorType":"negative"},
    {"field":"productFoundation","match":"目前不适合做实物产品","effects":{"productization":-18,"gift":-10},"reason":"当前不适合直接推进实物商品化，应先考虑体验或内容化。","factorType":"negative"},
